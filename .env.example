APP_NAME="PARTMATCH AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
APP_URL=http://localhost:8000

APP_LOCALE=ja
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ja_JP

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ===== DB不要のデモ構成 =====
# データは PHP 配列 + セッションで保持します。MySQL は使用しません。
# 既定接続は sqlite ですが、本デモはDBへ一切アクセスしません(空ファイルを同梱)。
DB_CONNECTION=sqlite

# セッション・キャッシュはファイルドライバ (DB不要)
SESSION_DRIVER=file
SESSION_LIFETIME=480
CACHE_STORE=file
QUEUE_CONNECTION=sync

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
